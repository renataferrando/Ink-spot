    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "geist": "^1.7.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.12.0",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.4",
    "radix-ui": "^1.4.3",
